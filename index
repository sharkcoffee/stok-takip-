<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Albayrak İnşaat - Stok Denetim Paneli</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9;
            color: #0f172a;
        }

        .card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        }

        .input-focus:focus {
            outline: none;
            border-color: #dc2626;
            box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
        }

        .status-badge {
            font-size: 0.65rem;
            font-weight: 800;
            padding: 0.25rem 0.6rem;
            border-radius: 0.5rem;
            text-transform: uppercase;
            display: inline-block;
        }

        .row-completed { background-color: #f8fafc !important; border-left: 4px solid #0f172a; }
        
        /* Mobil Kaydırma Çubuğu */
        .custom-scroll::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        .header-filter {
            width: 100%;
            font-size: 11px;
            padding: 5px 8px;
            border-radius: 6px;
            border: 1px solid #e2e8f0;
            margin-top: 6px;
            font-weight: 500;
        }

        #autosave-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
            display: none;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from { transform: translateY(-20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
    </style>
</head>
<body class="antialiased">

    <!-- Otomatik Kayıt Bildirimi -->
    <div id="autosave-toast" class="bg-white border border-emerald-100 shadow-xl px-4 py-2 rounded-full flex items-center gap-2">
        <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
        <span class="text-[10px] font-black uppercase text-slate-500 tracking-widest">Sistem Kaydedildi</span>
    </div>

    <div class="max-w-7xl mx-auto px-4 py-6 md:py-10">
        <!-- Başlık Bölümü -->
        <header class="flex flex-col md:flex-row justify-between items-center mb-8 gap-6">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-red-600 rounded-2xl flex items-center justify-center shadow-lg shadow-red-200">
                    <span class="text-white font-black text-2xl">A</span>
                </div>
                <div>
                    <h1 class="text-2xl font-black tracking-tighter text-slate-900 leading-tight">
                        ALBAYRAK <span class="text-red-600">STOK</span> TAKİP
                    </h1>
                    <p class="text-slate-400 font-bold text-[9px] uppercase tracking-[0.2em]">Stok Denetim ve Ambar Yönetimi</p>
                </div>
            </div>

            <div class="flex gap-3">
                <div class="bg-white px-5 py-3 rounded-2xl border border-slate-200 text-center min-w-[100px]">
                    <p class="text-[9px] font-black text-slate-400 uppercase">Toplam</p>
                    <p id="stat-total" class="text-xl font-black text-slate-800">0</p>
                </div>
                <div class="bg-white px-5 py-3 rounded-2xl border border-slate-200 text-center min-w-[100px] border-b-4 border-b-red-500">
                    <p class="text-[9px] font-black text-slate-400 uppercase">Eksik</p>
                    <p id="stat-deficit" class="text-xl font-black text-red-600">0</p>
                </div>
                <div class="bg-white px-5 py-3 rounded-2xl border border-slate-200 text-center min-w-[100px] border-b-4 border-b-emerald-500">
                    <p class="text-[9px] font-black text-slate-400 uppercase">Fazla</p>
                    <p id="stat-surplus" class="text-xl font-black text-emerald-600">0</p>
                </div>
            </div>
        </header>

        <!-- Filtre ve Arama Alanı -->
        <div class="flex flex-col md:flex-row gap-4 mb-6">
            <div class="relative flex-1">
                <input type="text" id="global-search" oninput="renderTable()" placeholder="KOD VEYA AÇIKLAMA İLE ARA..." 
                    class="w-full pl-12 pr-4 py-4 rounded-2xl border-none shadow-sm font-bold text-sm input-focus">
                <svg class="absolute left-4 top-4 text-slate-300" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
            </div>
            <button onclick="resetAllFilters()" class="bg-slate-200 hover:bg-slate-300 text-slate-600 px-6 py-4 rounded-2xl font-black text-[10px] uppercase transition-all">
                Filtreleri Temizle
            </button>
        </div>

        <!-- Ana Tablo -->
        <div class="bg-white rounded-3xl border border-slate-200 overflow-hidden card-shadow mb-8">
            <div class="overflow-x-auto custom-scroll">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-100">
                            <th class="p-4 align-top min-w-[140px]">
                                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest cursor-pointer" onclick="setSort('branch')">Şube ↕</div>
                                <input type="text" id="filter-branch" oninput="renderTable()" placeholder="Filtrele..." class="header-filter">
                            </th>
                            <th class="p-4 align-top min-w-[100px]">
                                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest cursor-pointer" onclick="setSort('warehouse')">Ambar ↕</div>
                                <input type="text" id="filter-warehouse" oninput="renderTable()" placeholder="Filtrele..." class="header-filter">
                            </th>
                            <th class="p-4 align-top min-w-[120px]">
                                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest cursor-pointer" onclick="setSort('code')">Kod ↕</div>
                                <input type="text" id="filter-code" oninput="renderTable()" placeholder="Filtrele..." class="header-filter">
                            </th>
                            <th class="p-4 align-top min-w-[250px]">
                                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest cursor-pointer" onclick="setSort('name')">Açıklama ↕</div>
                                <input type="text" id="filter-name" oninput="renderTable()" placeholder="Filtrele..." class="header-filter">
                            </th>
                            <th class="p-4 align-top text-center">
                                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Sistem</div>
                                <div class="h-[30px]"></div>
                            </th>
                            <th class="p-4 align-top text-center bg-red-50/30">
                                <div class="text-[10px] font-black text-red-600 uppercase tracking-widest">Sayım</div>
                                <div class="h-[30px]"></div>
                            </th>
                            <th class="p-4 align-top text-center">
                                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Fark</div>
                                <div class="h-[30px]"></div>
                            </th>
                            <th class="p-4 align-top text-center">
                                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Durum</div>
                                <select id="filter-status" onchange="renderTable()" class="header-filter">
                                    <option value="">TÜMÜ</option>
                                    <option value="BEKLİYOR">BEKLİYOR</option>
                                    <option value="TAMAM">TAMAM</option>
                                    <option value="EKSİK">EKSİK</option>
                                    <option value="FAZLA">FAZLA</option>
                                </select>
                            </th>
                            <th class="p-4 align-top text-right text-[10px] font-black text-slate-400 uppercase tracking-widest">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="inventory-body" class="divide-y divide-slate-50">
                        <!-- Veriler Buraya Gelecek -->
                    </tbody>
                </table>
            </div>
            <div id="empty-state" class="hidden p-20 text-center">
                <p class="text-slate-300 font-black text-xs uppercase tracking-[0.2em]">Kriterlere Uygun Kayıt Bulunamadı</p>
            </div>
        </div>

        <!-- Kayıt ve Aktarım Kontrolleri -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <!-- Form Alanı -->
            <div class="lg:col-span-8 bg-white p-6 rounded-3xl border border-slate-200 card-shadow">
                <h3 class="text-xs font-black text-slate-900 uppercase mb-5 tracking-widest flex items-center gap-2">
                    <span class="w-2 h-4 bg-red-600 rounded-full"></span> Yeni Malzeme Tanımla
                </h3>
                <form id="add-form" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <select id="in-branch" class="bg-slate-50 border-none p-4 rounded-xl font-bold text-xs input-focus"></select>
                    <input type="text" id="in-warehouse" placeholder="AMBAR" class="bg-slate-50 border-none p-4 rounded-xl font-bold text-xs input-focus uppercase">
                    <input type="text" id="in-code" placeholder="MALZEME KODU" class="bg-slate-50 border-none p-4 rounded-xl font-bold text-xs input-focus uppercase">
                    <input type="text" id="in-name" placeholder="MALZEME AÇIKLAMASI" class="bg-slate-50 border-none p-4 rounded-xl font-bold text-xs input-focus uppercase md:col-span-2">
                    <input type="number" id="in-qty" step="any" placeholder="SİSTEM STOĞU" class="bg-slate-50 border-none p-4 rounded-xl font-bold text-xs input-focus">
                    <button type="submit" class="md:col-span-3 bg-slate-900 hover:bg-black text-white font-black py-4 rounded-xl text-[10px] uppercase tracking-widest transition-all">
                        LİSTEYE EKLE
                    </button>
                </form>
            </div>

            <!-- Aksiyon Butonları -->
            <div class="lg:col-span-4 flex flex-col gap-3">
                <div class="flex gap-3">
                    <button onclick="exportExcel()" class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white p-5 rounded-3xl font-black text-[10px] uppercase transition-all shadow-lg shadow-emerald-100">Excel Aktar</button>
                    <button onclick="exportPDF()" class="flex-1 bg-red-600 hover:bg-red-700 text-white p-5 rounded-3xl font-black text-[10px] uppercase transition-all shadow-lg shadow-red-100">PDF Rapor</button>
                </div>
                <label class="w-full text-center bg-white border-2 border-dashed border-slate-200 text-slate-400 p-5 rounded-3xl font-black text-[10px] uppercase cursor-pointer hover:border-red-500 hover:text-red-500 transition-all">
                    Excel'den Toplu Veri Yükle
                    <input type="file" id="excel-upload" accept=".xlsx, .xls" class="hidden">
                </label>
                <button onclick="clearData()" class="text-slate-300 hover:text-red-500 font-bold text-[9px] uppercase tracking-widest mt-2">Tüm Verileri Sıfırla</button>
            </div>
        </div>
    </div>

    <script>
        // Veritabanı ve Sabitler
        const DB_KEY = 'albayrak_stok_v4_final';
        const BRANCHES = ["ALAKIR", "ELMALI", "KAŞ", "YEŞİLKÖY", "YEŞİLYURT"];
        const WAREHOUSE_DEFAULTS = { "ALAKIR": "(A)", "ELMALI": "(E)", "KAŞ": "(K)", "YEŞİLKÖY": "MERKEZ", "YEŞİLYURT": "ŞANTİYE" };

        let inventory = JSON.parse(localStorage.getItem(DB_KEY)) || [];
        let sortConfig = { key: 'id', dir: 'desc' };
        const numFormat = new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });

        // Başlatma
        function init() {
            const branchSel = document.getElementById('in-branch');
            BRANCHES.forEach(b => branchSel.add(new Option(b, b)));
            
            branchSel.onchange = () => {
                document.getElementById('in-warehouse').value = WAREHOUSE_DEFAULTS[branchSel.value] || "";
            };
            branchSel.dispatchEvent(new Event('change'));

            renderTable();
        }

        // Durum Hesaplama Mantığı
        function calculateStatus(item) {
            if (item.counted === null || item.counted === "" || isNaN(item.counted)) return "BEKLİYOR";
            const diff = parseFloat(item.counted) - parseFloat(item.qty);
            if (Math.abs(diff) < 0.001) return "TAMAM";
            return diff > 0 ? "FAZLA" : "EKSİK";
        }

        // Tabloyu Çizme (Filtreleme Dahil)
        function renderTable() {
            const search = document.getElementById('global-search').value.toLocaleUpperCase('tr-TR');
            const fBranch = document.getElementById('filter-branch').value.toLocaleUpperCase('tr-TR');
            const fWh = document.getElementById('filter-warehouse').value.toLocaleUpperCase('tr-TR');
            const fCode = document.getElementById('filter-code').value.toLocaleUpperCase('tr-TR');
            const fName = document.getElementById('filter-name').value.toLocaleUpperCase('tr-TR');
            const fStatus = document.getElementById('filter-status').value;

            let filtered = inventory.filter(item => {
                const status = calculateStatus(item);
                const b = item.branch.toLocaleUpperCase('tr-TR');
                const w = item.warehouse.toLocaleUpperCase('tr-TR');
                const c = item.code.toLocaleUpperCase('tr-TR');
                const n = item.name.toLocaleUpperCase('tr-TR');

                if (search && !`${b} ${w} ${c} ${n}`.includes(search)) return false;
                if (fBranch && !b.includes(fBranch)) return false;
                if (fWh && !w.includes(fWh)) return false;
                if (fCode && !c.includes(fCode)) return false;
                if (fName && !n.includes(fName)) return false;
                if (fStatus && status !== fStatus) return false;

                return true;
            });

            // Sıralama
            filtered.sort((a, b) => {
                let valA = a[sortConfig.key];
                let valB = b[sortConfig.key];
                if (typeof valA === 'string') {
                    return sortConfig.dir === 'asc' ? valA.localeCompare(valB, 'tr') : valB.localeCompare(valA, 'tr');
                }
                return sortConfig.dir === 'asc' ? valA - valB : valB - valA;
            });

            const body = document.getElementById('inventory-body');
            body.innerHTML = '';
            document.getElementById('empty-state').classList.toggle('hidden', filtered.length > 0);

            filtered.forEach(item => {
                const status = calculateStatus(item);
                const iQty = parseFloat(item.qty) || 0;
                const iCounted = (item.counted !== null && item.counted !== "") ? parseFloat(item.counted) : null;
                const diff = iCounted !== null ? (iCounted - iQty) : null;

                const tr = document.createElement('tr');
                tr.className = `transition-all ${iCounted !== null ? 'row-completed' : 'hover:bg-slate-50'}`;
                
                tr.innerHTML = `
                    <td class="p-4 font-black text-slate-800 text-[11px]">${item.branch}</td>
                    <td class="p-4 font-bold text-slate-400 text-[10px]">${item.warehouse}</td>
                    <td class="p-4 font-black text-slate-500 text-[10px]">${item.code}</td>
                    <td class="p-4 font-bold text-slate-700 text-xs">${item.name}</td>
                    <td class="p-4 text-center font-black text-slate-300 text-xs">${numFormat.format(iQty)}</td>
                    <td class="p-4 bg-red-50/20 text-center">
                        <input type="number" step="any" value="${item.counted ?? ''}" 
                               oninput="handleCountInput(${item.id}, this.value)"
                               class="w-20 text-center font-black text-sm p-2 rounded-xl border-2 border-slate-100 focus:border-red-500 outline-none transition-all">
                    </td>
                    <td id="diff-cell-${item.id}" class="p-4 text-center font-black text-xs ${diff > 0.001 ? 'text-emerald-600' : (diff < -0.001 ? 'text-red-600' : 'text-slate-300')}">
                        ${diff !== null ? (diff > 0 ? '+' : '') + numFormat.format(diff) : '-'}
                    </td>
                    <td class="p-4 text-center">
                        <span id="badge-${item.id}" class="status-badge ${status === 'TAMAM' ? 'bg-slate-900 text-white' : (status === 'FAZLA' ? 'bg-emerald-100 text-emerald-600' : (status === 'EKSİK' ? 'bg-red-100 text-red-600' : 'bg-slate-100 text-slate-400'))}">
                            ${status}
                        </span>
                    </td>
                    <td class="p-4 text-right">
                        <button onclick="deleteItem(${item.id})" class="text-slate-200 hover:text-red-600 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>
                    </td>
                `;
                body.appendChild(tr);
            });

            updateStats(filtered);
        }

        // Anlık Fark Güncelleme (Input Event)
        function handleCountInput(id, val) {
            const idx = inventory.findIndex(i => i.id === id);
            if (idx === -1) return;

            inventory[idx].counted = (val === "" || val === null) ? null : val;
            
            // UI Güncelleme (Anlık)
            const diffCell = document.getElementById(`diff-cell-${id}`);
            const badge = document.getElementById(`badge-${id}`);
            const tr = diffCell.closest('tr');
            
            const item = inventory[idx];
            const status = calculateStatus(item);
            const iQty = parseFloat(item.qty) || 0;
            const iCounted = (item.counted !== null && item.counted !== "") ? parseFloat(item.counted) : null;

            if (iCounted !== null) {
                const diff = iCounted - iQty;
                diffCell.innerText = (diff > 0 ? '+' : '') + numFormat.format(diff);
                diffCell.className = `p-4 text-center font-black text-xs ${diff > 0.001 ? 'text-emerald-600' : (diff < -0.001 ? 'text-red-600' : 'text-slate-300')}`;
                tr.classList.add('row-completed');
            } else {
                diffCell.innerText = '-';
                diffCell.className = `p-4 text-center font-black text-xs text-slate-300`;
                tr.classList.remove('row-completed');
            }

            badge.innerText = status;
            badge.className = `status-badge ${status === 'TAMAM' ? 'bg-slate-900 text-white' : (status === 'FAZLA' ? 'bg-emerald-100 text-emerald-600' : (status === 'EKSİK' ? 'bg-red-100 text-red-600' : 'bg-slate-100 text-slate-400'))}`;

            // Kaydet
            saveToStorage();
            updateStats(inventory);
        }

        function saveToStorage() {
            localStorage.setItem(DB_KEY, JSON.stringify(inventory));
            const toast = document.getElementById('autosave-toast');
            toast.style.display = 'flex';
            setTimeout(() => toast.style.display = 'none', 1000);
        }

        function updateStats(data) {
            let def = 0, sur = 0;
            data.forEach(i => {
                const s = calculateStatus(i);
                if (s === "EKSİK") def++;
                if (s === "FAZLA") sur++;
            });
            document.getElementById('stat-total').innerText = numFormat.format(data.length);
            document.getElementById('stat-deficit').innerText = numFormat.format(def);
            document.getElementById('stat-surplus').innerText = numFormat.format(sur);
        }

        function setSort(key) {
            if (sortConfig.key === key) sortConfig.dir = sortConfig.dir === 'asc' ? 'desc' : 'asc';
            else { sortConfig.key = key; sortConfig.dir = 'asc'; }
            renderTable();
        }

        function resetAllFilters() {
            ['global-search', 'filter-branch', 'filter-warehouse', 'filter-code', 'filter-name', 'filter-status'].forEach(id => {
                document.getElementById(id).value = '';
            });
            renderTable();
        }

        // Form Gönderimi
        document.getElementById('add-form').onsubmit = (e) => {
            e.preventDefault();
            const newItem = {
                id: Date.now(),
                branch: document.getElementById('in-branch').value,
                warehouse: document.getElementById('in-warehouse').value.toUpperCase(),
                code: document.getElementById('in-code').value.toUpperCase(),
                name: document.getElementById('in-name').value.toUpperCase(),
                qty: parseFloat(document.getElementById('in-qty').value) || 0,
                counted: null
            };
            inventory.unshift(newItem);
            saveToStorage();
            renderTable();
            e.target.reset();
            document.getElementById('in-branch').dispatchEvent(new Event('change'));
        };

        function deleteItem(id) {
            if (confirm("Bu kayıt silinecek, emin misiniz?")) {
                inventory = inventory.filter(i => i.id !== id);
                saveToStorage();
                renderTable();
            }
        }

        function clearData() {
            if (confirm("TÜM VERİLER SİLİNECEKTİR! Bu işlem geri alınamaz. Devam edilsin mi?")) {
                inventory = [];
                saveToStorage();
                renderTable();
            }
        }

        // Excel ve PDF İşlemleri
        function exportExcel() {
            const data = inventory.map(i => ({
                "ŞUBE": i.branch, "AMBAR": i.warehouse, "KOD": i.code, "AÇIKLAMA": i.name,
                "SİSTEM": i.qty, "SAYIM": i.counted || 0, "FARK": (parseFloat(i.counted || 0) - parseFloat(i.qty)), "DURUM": calculateStatus(i)
            }));
            const ws = XLSX.utils.json_to_sheet(data);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Stok_Rapor");
            XLSX.writeFile(wb, `Albayrak_Stok_Raporu_${new Date().toLocaleDateString()}.xlsx`);
        }

        async function exportPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('l', 'mm', 'a4');
            doc.text("ALBAYRAK INSAAT STOK SAYIM RAPORU", 15, 15);
            const rows = inventory.map(i => [i.branch, i.warehouse, i.code, i.name, i.qty, i.counted || '-', (parseFloat(i.counted || 0) - parseFloat(i.qty)).toFixed(2), calculateStatus(i)]);
            doc.autoTable({
                head: [['Şube', 'Ambar', 'Kod', 'Açıklama', 'Sistem', 'Sayım', 'Fark', 'Durum']],
                body: rows,
                startY: 22,
                theme: 'striped',
                styles: { fontSize: 7, font: 'helvetica' }
            });
            doc.save(`Albayrak_Rapor_${Date.now()}.pdf`);
        }

        // Excel Yükleme
        document.getElementById('excel-upload').onchange = (e) => {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (ev) => {
                const wb = XLSX.read(ev.target.result, { type: 'binary' });
                const data = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
                const imports = data.map(r => ({
                    id: Math.random() + Date.now(),
                    branch: String(r['ŞUBE'] || r['Şube'] || 'YEŞİLKÖY').toUpperCase(),
                    warehouse: String(r['AMBAR'] || r['Ambar'] || '').toUpperCase(),
                    code: String(r['KOD'] || r['Kod'] || '').toUpperCase(),
                    name: String(r['AÇIKLAMA'] || r['Açıklama'] || '').toUpperCase(),
                    qty: parseFloat(r['SİSTEM'] || r['Sistem'] || 0),
                    counted: null
                }));
                inventory = imports.concat(inventory);
                saveToStorage();
                renderTable();
            };
            reader.readAsBinaryString(file);
        };

        window.onload = init;
    </script>
</body>
</html>
